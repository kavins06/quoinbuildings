{
  "name": "quoinbuildings",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "setup:cloud": "npm run vercel:pull && npm run env:sync",
    "env:sync": "node -e \"const fs=require('fs'); const src='.vercel/.env.development.local'; const dst='.env.local'; if(!fs.existsSync(src)){throw new Error('Run npm run vercel:pull first.')} fs.copyFileSync(src,dst); console.log('Updated .env.local from Vercel development env.');\"",
    "vercel:link": "vercel link --yes",
    "vercel:pull": "vercel pull --yes --environment=development",
    "vercel:pull:prod": "vercel pull --yes --environment=production",
    "vercel:env:ls": "vercel env ls",
    "deploy:preview": "vercel",
    "deploy:prod": "vercel --prod",
    "supabase:status": "supabase status",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:db:push": "supabase db push",
    "supabase:link": "supabase link"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/instrument-serif": "^5.2.8",
    "@supabase/supabase-js": "^2.102.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "next": "^16.2.2",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "supabase": "^2.89.1",
    "vercel": "^50.44.0"
  }
}
