# Override the Google Calendar appointment-scheduling iframe URL on /contact.
# Leave unset to use the default URL hardcoded in app/contact/content.tsx.
NEXT_PUBLIC_BOOKING_URL=

# Apps Script webhook for the existing /contact form. Reused by /api/assessment.
APPS_SCRIPT_CONTACT_URL=

# Resend (AI Readiness Assessment email + PDF delivery).
# Domain DNS setup at https://resend.com/domains is required before launch.
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=noreply@quoinbuildings.com

# Internal address that receives a copy of every assessment submission
# (also used as the backup notification target if the Apps Script CRM POST fails).
ASSESSMENT_NOTIFICATION_EMAIL=hi@quoinbuildings.com
